                  <p>
                    Укажите код:<br/>
                    <input type="text" name="captcha" class="cinp"/><br/>
                    <a href="#" onclick="reloadImg();return false;">Не вижу код</a>
                  </p>
                  <p>
                    <img id="captcha" src="/web/20260104194646im_/https://blocklist.net.ua/system/security/index.php"/>
                  </p>
                </div>
                <input type="submit" id="buttonsubm" class="btn-green" value="Снять блокировку"/>
