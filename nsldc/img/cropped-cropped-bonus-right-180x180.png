  <script type="text/javascript">
    var ipval;
    var inpred = false;
    var re = /[^0-9\.]/gi;

    function checkIP(ipval, click) {
      var vinp = document.getElementById("vinp");
      if (re.test(ipval) || ipval === '') {
        vinp.value = ipval.replace(re, '');
        return false;
      } else {
        setred = true;
        checkres = false;
        iparr = ipval.split(".");
        if(iparr.length<=4){
          for(i=0;i<iparr.length;i++){
            numpart = parseInt(iparr[i]);
            if(numpart >= 0 && numpart <= 255) {
              if(inpred)
                vinp.setAttribute("class", "");
              setred = false;
            } else {
              setred = true;
              break;
            }
          }
          if(i==4)
            checkres = true;
        }
        if(setred || click && !checkres) {
          inpred = true;
          vinp.setAttribute("class", "red");
        }
        return checkres;
      }
    }
  </script>

